{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Markdown Editor",
  "version": "1.0.0",
  "identifier": "com.markdown-editor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5000",
    "beforeBuildCommand": "pnpm vite build",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Editor",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
