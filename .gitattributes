# Auto detect text files and normalize to LF
* text=auto

# Explicitly set LF for common text types
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.rs text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf